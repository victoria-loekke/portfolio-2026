---
import Layout from "../layouts/Layout.astro";
import ProjectCardGrid from "../components/ProjectCardGrid.astro";
import ProjectCardPhone from "../components/ProjectCardPhone.astro";
import { projects } from "../data/projects.js";
import BulletSchool from "../components/BulletSchool.astro";
import List from "../components/List.astro";
import ProjectCardFeed from "../components/ProjectCardFeed.astro";
---

<Layout title="About Victoria" current="projects">
  <div class="hidden lg:block">
    <div id="filterBar" class="flex justify-between">
      <button data-view="about">about me</button>
      <button data-view="school">education</button>
      <button data-view="work">experience</button>
    </div>

    <div id="views">
      <div data-layout="about">
        <div class="grid grid-cols-2 gap-4">
          <img src="/images/dig.jpg" alt="" />

          <div>
         <p class="text-3xl">Hi, I'm Victoria Løkke — a front-end developer and designer from Copenhagen, Denmark, currently studying Coded Design at the Danish School of media and design, where I get to do what I love most: combining thoughtful design with clean, purposeful code.
I enjoy the process of taking something from a visual idea to a fully realised digital experience — paying attention to both how it looks and how it works. For me, good design and good code go hand in hand.
When I'm not at my laptop, you'll probably find me working on a knitting project or exploring the world. 
</p>
          </div>
        </div>
      </div>
    </div>

 <div data-layout="school" class="hidden">
  <div class="flex flex-col">

     <List
            text="Danish School of Media and Journalism"
            date="2024—27"
            line="Coded Design — Visual Communication"
          />

              <List
            text="Copenhagen School of Design and Technology"
            date="2020-22"
            line="Multimediadesign"
          />


    <List
            text="Metaforá Studio Arts Bareclona"
            date="2019"
            line="Semester in Fine Arts"
          />


    <List
            text="Ordrup Gymnasium"
            date="2015-18"
            line="Upper Secondary Education"
          />
   </div>
</div>

 <div data-layout="work" class="hidden">
  <div class="flex flex-col">

     <List
            text="Red Cross Denmark"
            date="2025-"
            line="Voluenteer"
          />

              <List
            text="Indepentent freelancer"
            date="2023-"
            line="Freelancer as web-developer/grapic designer"
          />

    <List
            text="Founder of Vicz Gemz"
            date="2022-24"
            line="Started a tooth gems shop working with brands like Ganni & Tiktok"
          />


    <List
            text="Ordrup Gymnasium"
            date="2015-18"
            line="Upper Secondary Education"
          />
   </div>
</div>
  </div>
</Layout>

<div class="lg:hidden">
  <p>mobil version</p>
</div>

<style>
  .prik {
    font-size: 4rem;
    margin: 0;
  }
  #filterBar button {
    opacity: 0.5;
  }
  #filterBar button:hover,
  #filterBar button.active {
    opacity: 1;
  }
  .to-top {
    position: fixed;
    bottom: 24px;
    right: 24px;
    padding: 8px 12px;
    cursor: pointer;
    z-index: 100;
  }

  .to-top.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .to-top {
    transition: opacity 0.3s ease;
  }
</style>

<script>
  const buttons = document.querySelectorAll("[data-view]");
  const layouts = document.querySelectorAll("[data-layout]");
  document.querySelector('[data-view="about"]').classList.add("active");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const view = btn.dataset.view;

      buttons.forEach((b) => b.classList.remove("active"));

      btn.classList.add("active");

      layouts.forEach((layout) => {
        layout.classList.add("hidden");
      });

      document
        .querySelector(`[data-layout="${view}"]`)
        .classList.remove("hidden");
    });
  });
</script>
