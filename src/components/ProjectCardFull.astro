---
const { project } = Astro.props;
---

<a
  href={`/projects/${project.slug}`}
  class="project-card"
  data-project={project.slug}
>
  <img src={project.image} alt={project.title} />

  <div class="overlay">
 
  <div class="flex flex-wrap items-baseline">
     <h3 class="mt-2 black">Who? </h3>
      <h3 class="mx-1">{project.client}</h3>
  </div>
    <div class="flex flex-wrap items-baseline">
     <h3 class="mt-1 black">What? </h3>
      <h3 class="mx-1">{project.case}</h3>
  </div>
    <div class="flex flex-wrap items-baseline">
     <h3 class="mt-1 black">When? </h3>
      <h3 class="mx-1">{project.date}</h3>
  </div>
  </div>
</a>

<style>
    .black{
        font-weight: 900;
    }
  .project-card {
    position: relative;
    display: block;
  }

  .project-card img {
    width: 100%;
    height: 78vh;
    display: block;
    aspect-ratio: 1/1;
    object-fit: cover;
    transition: filter 0.4s ease;
  }

  .overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1rem;

    transition: opacity 0.3s ease;
  }
</style>
