---
const { text, date, line } = Astro.props;
---

<div class="mt-6 flex items-center gap-3">
  <div
    class="flex flex-wrap items-baseline gap-2 text-2xl 2xl:text-3xl"
  >
    <h1>●</h1>
    <h1 class="text-[#1A0FAB] underline">
      {text}
    </h1>

    <h1>{date}</h1>
  </div>
</div>
<h3 class="mx-7 mt-2 text-[#681DA8] underline">{line}</h3>

<style>
  h1 {

    font-family: "Neue Haas Grotesk", sans-serif;
    font-weight: 300;
  }

    h3 {
    font-size: 1.2rem;
    font-family: "Neue Haas Grotesk", sans-serif;
    font-weight: 300;
  }
</style>
