---
const { text, date, line } = Astro.props;
---

<div class="grid grid-cols-[2fr_1fr] items-stretch border-b border-[#191817] dark-border py-2 mt-4">
  
  <div class="flex flex-col ">
    <p class="text-4xl">{text}</p>
    <p class="text-2xl">{line}</p>
  </div>
  <h1 class="text-8xl text-right leading-none font-[#191817]">{date}</h1>
</div>
