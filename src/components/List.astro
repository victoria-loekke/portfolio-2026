---
const { text, date, line } = Astro.props;
---

<div class="grid grid-cols-[1fr_2fr] items-stretch border-b border-[#191817] dark-border py-4">
  
  <div class="flex flex-col items-end pl-6">
    <p class="text-4xl">{text}</p>
    <p class="text-2xl">{line}</p>
  </div>
  <h1 class="text-8xl leading-none font-[#191817]">{date}</h1>
</div>
