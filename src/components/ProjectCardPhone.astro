---
const { project } = Astro.props;
---

<a href={`/projects/${project.slug}`}>
  <div class="mb-4">
    <img src={project.image} alt={project.title} />
    <h3 class="text-3xl mt-2">Who? {project.client}</h3>
    <h3 class="text-3xl">What? {project.case}</h3>
    <h3 class="text-3xl">When? {project.date}</h3>
  </div>
</a>

<style>
  img {
    filter: invert(0);
    transition: filter 0.4s ease;
    width: 100%;
    aspect-ratio: 1/1;
    object-fit: cover;
  }

  img:hover {
    filter: invert(100);
    transition: filter 0.4s ease;
  }
</style>
