---
const { project } = Astro.props;
---

<a href={`/projects/${project.slug}`} class="project-card">
  <div
    class="slider"
    data-gallery={[project.image, ...project.gallery].join(",")}
  >
    <div class="slider-track">
      {
        [project.image, ...project.gallery].map((img) => (
          <img src={img} />
        ))
      }
    </div>
  </div>

  <div class="flex flex-wrap items-baseline">
     <h3 class="mt-2 black">Who? </h3>
      <h3 class="mx-1">{project.client}</h3>
  </div>
    <div class="flex flex-wrap items-baseline">
     <h3 class="mt-1 black">What? </h3>
      <h3 class="mx-1">{project.case}</h3>
  </div>
    <div class="flex flex-wrap items-baseline">
     <h3 class="mt-1 black">When? </h3>
      <h3 class="mx-1">{project.date}</h3>
  </div>

</a>

<style>
    .black{
        font-weight:900;
    }
  .project-card {
    display: block;
  }

  .project-card img {
    width: 100%;
    display: block;
    aspect-ratio: 1/1;
    object-fit: cover;
  }

  .slider {
    overflow: hidden;
    aspect-ratio: 1/1;
    position: relative;
  }

  .slider-track {
    display: flex;
    height: 100%;

    transition: transform 0.2s ease;
  }

  .slider-track img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    flex-shrink: 0;
  }
</style>
<script>
  document.querySelectorAll(".slider").forEach((slider) => {
    const track = slider.querySelector(".slider-track");
    const images = track.querySelectorAll("img");

    let index = 0;
    let interval;

    slider.addEventListener("mouseenter", () => {
      interval = setInterval(() => {
        index = (index + 1) % images.length;

        track.style.transform = `translateX(-${index * 100}%)`;
      }, 1100);
    });

    slider.addEventListener("mouseleave", () => {
      clearInterval(interval);
      index = 0;
      track.style.transform = `translateX(0%)`;
    });
  });
</script>
