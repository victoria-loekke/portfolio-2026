---
const { project } = Astro.props;
---

<a href={`/projects/${project.slug}`} class="project-card">
  <div
    class="slider"
    data-gallery={[project.image, ...project.gallery].join(",")}
  >
    <div class="slider-track">
      {[project.image, ...project.gallery].map((img) => <img src={img} loading="lazy"/>)}
    </div>
  </div>

  <div class="flex flex-wrap items-baseline">
    <h3 class="black mt-2">Who?</h3>
    <h3 class="mx-1">{project.client}</h3>
  </div>
  <div class="flex flex-wrap items-baseline">
    <h3 class="black mt-1">What?</h3>
    <h3 class="mx-1">{project.case}</h3>
  </div>
  <div class="flex flex-wrap items-baseline">
    <h3 class="black mt-1">When?</h3>
    <h3 class="mx-1">{project.date}</h3>
  </div>
</a>

<style>
  .black {
    font-weight: 900;
  }
  .project-card {
    display: block;
  }

  .project-card img {
    width: 100%;
    display: block;
    aspect-ratio: 1/1;
    object-fit: cover;
  }
  .slider {
    overflow: hidden;
    aspect-ratio: 1/1;
    position: relative;
  }

  .slider-track {
    position: relative;
    height: 100%;
  }

  .slider-track img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.1s ease;
  }

  .slider-track img:first-child {
    opacity: 1;
  }
</style>
<script>
  document.querySelectorAll(".slider").forEach((slider) => {
    const track = slider.querySelector(".slider-track");
    const images = track.querySelectorAll("img");

    let index = 0;
    let interval;

    slider.addEventListener("mouseenter", () => {
      interval = setInterval(() => {
        images[index].style.opacity = "0";
        index = (index + 1) % images.length;
        images[index].style.opacity = "1";
      }, 400);
    });

    slider.addEventListener("mouseleave", () => {
      clearInterval(interval);
      images[index].style.opacity = "0";
      index = 0;
      images[0].style.opacity = "1";
    });
  });
</script>
